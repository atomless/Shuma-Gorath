{
  "schema_version": "container-runtime-profile.v1",
  "required_flags": [
    "--rm",
    "--read-only",
    "--cap-drop=ALL",
    "--security-opt=no-new-privileges",
    "--pids-limit=128",
    "--memory=256m",
    "--cpus=1.0",
    "--tmpfs=/tmp:rw,nosuid,nodev,size=64m"
  ],
  "required_flag_groups_any_of": [
    [
      "--add-host=host.docker.internal:host-gateway",
      "--network=bridge"
    ],
    [
      "--network=host"
    ]
  ],
  "forbidden_flag_prefixes": [
    "--privileged",
    "--pid=host",
    "--ipc=host",
    "--uts=host",
    "--userns=host"
  ],
  "forbidden_mount_substrings": [
    "/var/run/docker.sock",
    "/run/containerd/containerd.sock",
    "/:/",
    "/proc:/",
    "/sys:/"
  ],
  "required_user_mode": "non_root_image_user",
  "llm_fulfillment_runtime": {
    "schema_version": "adversary-sim-llm-runtime-profile.v1",
    "browser_mode": {
      "browser_automation_allowed": true,
      "direct_request_emission_allowed": false,
      "max_actions": 8,
      "max_time_budget_seconds": 90
    },
    "request_mode": {
      "browser_automation_allowed": false,
      "direct_request_emission_allowed": true,
      "max_actions": 24,
      "max_time_budget_seconds": 120
    }
  }
}
