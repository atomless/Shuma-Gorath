{
  "schema_version": "frontier-action-contract.v1",
  "allowed_tools": [
    "http_get"
  ],
  "network_constraints": {
    "allowed_schemes": [
      "http",
      "https"
    ],
    "enforce_single_origin_from_allowlist": true,
    "forbidden_hostnames": [
      "169.254.169.254",
      "metadata.google.internal",
      "metadata.aws.internal",
      "metadata"
    ]
  },
  "budgets": {
    "max_actions_per_run": 24,
    "max_time_budget_seconds": 120,
    "max_query_pairs_per_action": 6
  },
  "forbidden_data_access": {
    "forbidden_env_prefixes": [
      "SHUMA_"
    ],
    "forbidden_env_keys": [
      "SHUMA_API_KEY",
      "SHUMA_ADMIN_READONLY_API_KEY",
      "SHUMA_JS_SECRET",
      "SHUMA_CHALLENGE_SECRET",
      "SHUMA_HEALTH_SECRET",
      "SHUMA_FORWARDED_IP_SECRET",
      "SHUMA_SIM_TELEMETRY_SECRET"
    ],
    "forbidden_headers": [
      "authorization",
      "x-shuma-api-key",
      "x-shuma-challenge-secret",
      "x-shuma-forwarded-secret",
      "x-shuma-health-secret",
      "x-shuma-js-secret"
    ],
    "forbidden_path_prefixes": [
      "/admin/"
    ]
  },
  "dsl": {
    "schema_version": "frontier-action-dsl.v1",
    "allowed_action_types": [
      "http_get"
    ],
    "required_action_keys": [
      "action_type",
      "path"
    ],
    "optional_action_keys": [
      "query",
      "label"
    ],
    "max_path_length": 256,
    "max_query_length": 512,
    "max_label_length": 80
  },
  "default_actions": [
    {
      "action_type": "http_get",
      "path": "/",
      "label": "root"
    },
    {
      "action_type": "http_get",
      "path": "/sim/public/",
      "label": "latest"
    },
    {
      "action_type": "http_get",
      "path": "/sim/public/about/",
      "label": "about"
    },
    {
      "action_type": "http_get",
      "path": "/sim/public/research/",
      "label": "research"
    },
    {
      "action_type": "http_get",
      "path": "/sim/public/plans/",
      "label": "plans"
    },
    {
      "action_type": "http_get",
      "path": "/sim/public/work/",
      "label": "work"
    }
  ],
  "llm_fulfillment": {
    "schema_version": "adversary-sim-llm-fulfillment-contract.v1",
    "backend_kinds": [
      "frontier_reference",
      "local_candidate"
    ],
    "modes": {
      "browser_mode": {
        "reference_backend_kind": "frontier_reference",
        "allowed_tools": [
          "browser_navigate",
          "browser_snapshot",
          "browser_click"
        ],
        "category_targets": [
          "browser_agent",
          "agent_on_behalf_of_human"
        ]
      },
      "request_mode": {
        "reference_backend_kind": "frontier_reference",
        "allowed_tools": [
          "http_get"
        ],
        "category_targets": [
          "http_agent",
          "ai_scraper_bot"
        ]
      }
    }
  },
  "llm_attacker_black_box": {
    "schema_version": "adversary-sim-llm-attacker-black-box.v1",
    "position": "outside_attacker",
    "host_root_only_entrypoint": true,
    "category_objective_required": true,
    "malicious_category_priming_required": true,
    "public_knowledge_only": true,
    "shuma_blind": true,
    "web_search_allowed": false,
    "repo_visibility_allowed": false,
    "judge_visibility_allowed": false,
    "public_host_hint_sources": [
      "robots_txt",
      "sitemap_references",
      "traversal_visible_pages"
    ],
    "allowed_observation_families": [
      "root_response",
      "public_host_hints",
      "traversal_observations",
      "response_metadata",
      "content_snapshots"
    ],
    "forbidden_knowledge_sources": [
      "shuma_repo",
      "shuma_docs",
      "shuma_source_code",
      "shuma_internal_routes",
      "shuma_defense_inventory",
      "admin_credentials",
      "judge_state",
      "web_search"
    ],
    "receipt_requirements": {
      "attack_trace_required": true,
      "observation_lineage_required": true,
      "category_objective_lineage_required": true
    }
  },
  "llm_attacker_episode_harness": {
    "schema_version": "adversary-sim-llm-attacker-episode.v1",
    "initial_context_fields": [
      "host_root_entrypoint",
      "category_objective",
      "black_box_boundary",
      "capability_envelope"
    ],
    "environment_reset_required": true,
    "environment_reset_policy": "fresh_episode_reset",
    "bounded_action_horizon_required": true,
    "terminal_conditions": [
      "objective_completed",
      "action_budget_exhausted",
      "time_budget_exhausted",
      "hard_guardrail_triggered",
      "environment_unavailable"
    ],
    "failure_states": [
      "objective_unfulfilled",
      "environment_error",
      "guardrail_refusal"
    ],
    "allowed_memory_sources": [
      "prior_episode_summaries",
      "player_visible_protected_evidence",
      "public_host_discoveries",
      "curriculum_strategy_notes"
    ],
    "forbidden_memory_sources": [
      "judge_held_out_evaluation",
      "raw_regression_anchor_inventory",
      "admin_or_secret_material",
      "shuma_internal_knowledge"
    ],
    "max_retained_episode_summaries": 5,
    "max_curriculum_items": 8,
    "player_visible_protected_evidence_allowed": true,
    "held_out_evaluation_visible": false
  }
}
