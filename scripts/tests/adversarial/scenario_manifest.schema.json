{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://shuma-gorath.local/schemas/adversarial-scenario-manifest.schema.json",
  "title": "Shuma Adversarial Scenario Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "suite_id",
    "description",
    "profiles",
    "scenarios"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "sim-manifest.v1",
        "sim-manifest.v2"
      ]
    },
    "suite_id": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/definitions/profile"
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/scenario"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "sim-manifest.v1"
          }
        }
      },
      "then": {
        "properties": {
          "scenarios": {
            "items": {
              "required": [
                "assertions"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "sim-manifest.v2"
          }
        }
      },
      "then": {
        "properties": {
          "scenarios": {
            "items": {
              "required": [
                "traffic_model",
                "expected_defense_categories",
                "coverage_tags",
                "cost_assertions"
              ]
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "profile": {
      "type": "object",
      "required": [
        "description",
        "max_runtime_seconds",
        "scenario_ids",
        "gates"
      ],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "minLength": 8
        },
        "max_runtime_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "scenario_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "gates": {
          "type": "object",
          "required": [
            "latency",
            "outcome_ratio_bounds",
            "telemetry_amplification"
          ],
          "additionalProperties": false,
          "properties": {
            "latency": {
              "type": "object",
              "required": [
                "p95_max_ms"
              ],
              "additionalProperties": false,
              "properties": {
                "p95_max_ms": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 120000
                }
              }
            },
            "outcome_ratio_bounds": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "$ref": "#/definitions/ratioBound"
              }
            },
            "telemetry_amplification": {
              "type": "object",
              "required": [
                "max_fingerprint_events_per_request",
                "max_monitoring_events_per_request"
              ],
              "additionalProperties": false,
              "properties": {
                "max_fingerprint_events_per_request": {
                  "type": "number",
                  "minimum": 0
                },
                "max_monitoring_events_per_request": {
                  "type": "number",
                  "minimum": 0
                }
              }
            },
            "coverage_requirements": {
              "type": "object",
              "minProperties": 1,
              "propertyNames": {
                "enum": [
                  "honeypot_hits",
                  "challenge_failures",
                  "not_a_bot_pass",
                  "not_a_bot_fail",
                  "not_a_bot_replay",
                  "not_a_bot_escalate",
                  "pow_attempts",
                  "pow_successes",
                  "pow_failures",
                  "rate_violations",
                  "rate_limited",
                  "rate_banned",
                  "geo_violations",
                  "geo_challenge",
                  "geo_maze",
                  "geo_block",
                  "maze_hits",
                  "tarpit_activations_progressive",
                  "tarpit_progress_advanced",
                  "cdp_detections",
                  "fingerprint_events",
                  "ban_count",
                  "recent_event_count"
                ]
              },
              "additionalProperties": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "ratioBound": {
      "type": "object",
      "required": [
        "min",
        "max"
      ],
      "additionalProperties": false,
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "scenario": {
      "type": "object",
      "required": [
        "id",
        "description",
        "tier",
        "driver",
        "expected_outcome",
        "ip",
        "user_agent",
        "seed",
        "runtime_budget_ms"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "description": {
          "type": "string",
          "minLength": 8
        },
        "tier": {
          "type": "string",
          "enum": [
            "SIM-T0",
            "SIM-T1",
            "SIM-T2",
            "SIM-T3",
            "SIM-T4"
          ]
        },
        "driver": {
            "type": "string",
            "enum": [
              "allow_browser_allowlist",
              "not_a_bot_pass",
              "pow_success",
              "pow_invalid_proof",
              "rate_limit_enforce",
              "geo_challenge",
              "geo_maze",
              "geo_block",
              "honeypot_deny_temp",
              "not_a_bot_replay_abuse",
              "not_a_bot_stale_token_abuse",
              "not_a_bot_ordering_cadence_abuse",
              "akamai_additive_report",
            "akamai_authoritative_deny"
          ]
        },
        "expected_outcome": {
          "type": "string",
          "enum": [
            "allow",
            "monitor",
            "not-a-bot",
            "challenge",
            "maze",
            "deny_temp"
          ]
        },
        "ip": {
          "type": "string",
          "minLength": 7
        },
        "user_agent": {
          "type": "string",
          "minLength": 3
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "geo_country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "payload_fixture": {
          "type": "string",
          "minLength": 3
        },
        "runtime_budget_ms": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120000
        },
        "traffic_model": {
          "type": "object",
          "required": [
            "persona",
            "think_time_ms_min",
            "think_time_ms_max",
            "retry_strategy",
            "cookie_behavior"
          ],
          "additionalProperties": false,
          "properties": {
            "persona": {
              "type": "string",
              "enum": [
                "human_like",
                "benign_automation",
                "suspicious_automation",
                "adversarial"
              ]
            },
            "think_time_ms_min": {
              "type": "integer",
              "minimum": 0
            },
            "think_time_ms_max": {
              "type": "integer",
              "minimum": 0
            },
            "retry_strategy": {
              "type": "string",
              "enum": [
                "single_attempt",
                "bounded_backoff",
                "retry_storm"
              ]
            },
            "cookie_behavior": {
              "type": "string",
              "enum": [
                "stateful_cookie_jar",
                "stateless",
                "cookie_reset_each_request"
              ]
            }
          }
        },
        "expected_defense_categories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "allowlist",
              "not_a_bot",
              "challenge",
              "pow",
              "rate_limit",
              "geo",
              "maze",
              "tarpit",
              "honeypot",
              "cdp",
              "fingerprint",
              "ban_path",
              "event_stream"
            ]
          },
          "uniqueItems": true
        },
        "coverage_tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "cost_assertions": {
          "type": "object",
          "required": [
            "max_latency_ms"
          ],
          "additionalProperties": false,
          "properties": {
            "max_latency_ms": {
              "type": "integer",
              "minimum": 1,
              "maximum": 120000
            }
          }
        },
        "assertions": {
          "type": "object",
          "required": [
            "max_latency_ms"
          ],
          "additionalProperties": false,
          "properties": {
            "max_latency_ms": {
              "type": "integer",
              "minimum": 1,
              "maximum": 120000
            }
          }
        }
      }
    }
  }
}
